<h1>Import Trade Republic</h1>

<!-- ── Formulaire upload ───────────────────────────────────────── -->
<div class="card" id="upload-card">
  <h2>Importer un CSV Trade Republic</h2>
  <p style="color:#94a3b8;font-size:0.875rem;margin-bottom:1rem">
    Exportez depuis l'app TR → <em>Profil → Documents → Exportation de transactions</em>.
    Chaque ligne CSV peut générer plusieurs transactions SUR (principal, frais, taxes séparément).
  </p>

  <% if defined?(@error) && @error %>
    <div style="background:#450a0a;border:1px solid #7f1d1d;border-radius:0.5rem;padding:0.75rem 1rem;margin-bottom:1rem;color:#f87171">
      <%= @error %>
    </div>
  <% end %>

  <form id="import-form" method="post" action="/import" enctype="multipart/form-data">
    <div class="grid grid-2" style="gap:1rem">
      <div>
        <label>Fichier CSV</label>
        <input type="file" name="file" id="file-input" accept=".csv" required>
      </div>
      <div>
        <label>Importer à partir du (optionnel)</label>
        <input type="date" name="from_date" id="from-date" value="<%= params[:from_date] %>">
      </div>
    </div>

    <div style="margin-top:1rem;display:flex;gap:1rem;align-items:center;flex-wrap:wrap">
      <button class="btn btn-primary" type="submit" name="dry_run" value="true">
        Aperçu (dry-run)
      </button>
      <button class="btn" style="background:#065f46;color:#6ee7b7" type="button" id="import-btn">
        Importer réellement
      </button>
      <span style="color:#64748b;font-size:0.8rem">L'aperçu ne fait rien — il simule le résultat.</span>
      <button class="btn" style="background:#1e293b;color:#94a3b8;margin-left:auto" type="button" id="discover-btn">
        🔍 Vérifier comptes SUR
      </button>
    </div>
  </form>

  <!-- Zone purge -->
  <div style="margin-top:1.5rem;padding-top:1rem;border-top:1px solid #334155">
    <div style="font-size:0.8rem;color:#64748b;margin-bottom:0.75rem">
      Données existantes dans SUR — à utiliser si un import précédent avait des erreurs (signes, labels…)
    </div>
    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center">
      <button class="btn btn-sm" style="background:#450a0a;color:#fca5a5" type="button"
              id="purge-txn-btn">🗑 Supprimer les transactions TR</button>
      <button class="btn btn-sm" style="background:#422006;color:#fed7aa" type="button"
              id="purge-trades-btn">🗑 Supprimer les trades TR</button>
      <span id="purge-status" style="font-size:0.8rem;color:#64748b"></span>
    </div>
  </div>

  <!-- Résultat discover -->
  <div id="discover-result" style="display:none;margin-top:1rem;background:#0f172a;border:1px solid #334155;border-radius:0.5rem;padding:1rem">
    <div style="font-size:0.75rem;color:#64748b;margin-bottom:0.5rem">Comptes SUR détectés</div>
    <pre id="discover-json" style="font-size:0.75rem;color:#94a3b8;overflow:auto;max-height:200px"></pre>
  </div>
</div>

<!-- ── Progress bar (import réel) ─────────────────────────────── -->
<div class="card" id="progress-card" style="display:none">
  <h2 id="progress-title">Import en cours…</h2>

  <div style="margin:1.5rem 0">
    <div style="display:flex;justify-content:space-between;margin-bottom:0.5rem">
      <span id="progress-label" style="font-size:0.875rem;color:#94a3b8">Démarrage…</span>
      <span id="progress-pct" style="font-size:0.875rem;font-weight:600;color:#38bdf8">0%</span>
    </div>
    <div style="background:#1e293b;border-radius:9999px;height:10px;overflow:hidden">
      <div id="progress-bar" style="background:#0369a1;height:100%;width:0%;transition:width 0.3s ease;border-radius:9999px"></div>
    </div>
    <div style="display:flex;gap:2rem;margin-top:1rem">
      <div class="stat">
        <div class="stat-value" id="p-ok" style="color:#4ade80">0</div>
        <div class="stat-label">Importées</div>
      </div>
      <div class="stat">
        <div class="stat-value" id="p-errors" style="color:#f87171">0</div>
        <div class="stat-label">Erreurs</div>
      </div>
      <div class="stat">
        <div class="stat-value" id="p-skip" style="color:#64748b">0</div>
        <div class="stat-label">Déjà présentes</div>
      </div>
      <div class="stat">
        <div class="stat-value" id="p-total" style="color:#94a3b8">—</div>
        <div class="stat-label">Total</div>
      </div>
    </div>
  </div>
</div>

<!-- ── Résultats (dry-run server-side OU import JS) ───────────── -->
<div id="results-section">
<% if @result %>
  <%# ── ISINs non mappés ──────────────────────────────────────────────── %>
  <% if @result.unmapped&.any? %>
    <div class="card" style="border-color:#b45309" id="unmapped-card">
      <h2 style="color:#fbbf24;margin-bottom:0.5rem">
        ⚠️ <%= @result.unmapped.size %> titre<%= @result.unmapped.size > 1 ? 's' : '' %> sans correspondance Yahoo Finance
      </h2>
      <p style="color:#94a3b8;font-size:0.875rem;margin-bottom:1rem">
        Ces titres ne seront <strong>pas importés</strong> tant qu'ils ne sont pas mappés.
        Entrez le ticker Yahoo Finance puis cliquez Sauvegarder. Relancez ensuite l'aperçu.
      </p>
      <table>
        <thead><tr><th>ISIN</th><th>Nom</th><th>Ticker Yahoo Finance</th><th></th></tr></thead>
        <tbody>
          <% @result.unmapped.each do |u| %>
            <tr id="unmapped-row-<%= u[:isin] %>">
              <td style="color:#94a3b8;font-family:monospace"><%= u[:isin] %></td>
              <td><%= u[:name] %></td>
              <td>
                <input type="text" id="ticker-<%= u[:isin] %>"
                       placeholder="ex: AAPL, TTE.PA, BTC-USD"
                       style="width:180px"
                       data-isin="<%= u[:isin] %>"
                       data-name="<%= u[:name].gsub('"','&quot;') %>">
              </td>
              <td>
                <button class="btn btn-primary btn-sm save-ticker-btn"
                        data-isin="<%= u[:isin] %>">
                  Sauvegarder
                </button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <% rows = @result.rows %>
  <% by_tag = rows.group_by(&:tag) %>

  <div class="card">
    <h2 style="margin-bottom:1rem">
      Aperçu — <%= rows.size %> nouvelles transactions
      <% if @result.skipped > 0 %>
        <span style="font-size:0.85rem;font-weight:400;color:#64748b;margin-left:0.5rem">
          (<%= @result.skipped %> déjà importées, ignorées)
        </span>
      <% end %>
    </h2>

    <div style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-bottom:1.5rem">
      <% by_tag.sort_by { |tag, _| ['Investissement','Dividende','Dépôt','Retrait','Intérêts','Frais de courtage','Taxes','Frais','Virement interne','Autre'].index(tag) || 99 }.each do |tag, tag_rows| %>
        <% tot = tag_rows.sum(&:amount).round(2) %>
        <div style="background:#0f172a;border:1px solid #334155;border-radius:0.5rem;padding:0.5rem 0.875rem;min-width:130px">
          <div style="font-size:0.75rem;color:#64748b;margin-bottom:0.25rem"><%= tag %></div>
          <div style="font-size:0.9rem;font-weight:600;color:<%= tot >= 0 ? '#4ade80' : '#f87171' %>"><%= tot >= 0 ? '+' : '' %><%= tot %>€</div>
          <div style="font-size:0.75rem;color:#475569"><%= tag_rows.size %> ligne<%= tag_rows.size > 1 ? 's' : '' %></div>
        </div>
      <% end %>
    </div>

    <table>
      <thead><tr><th>Date</th><th>Compte</th><th>Type</th><th>Montant</th><th>Catégorie</th><th>Libellé</th></tr></thead>
      <tbody>
        <% rows.each do |row| %>
          <% tag_color = {'Trade'=>'badge-blue','Dividende'=>'badge-green','Dépôt'=>'badge-green','Taxes'=>'badge-red','Frais de courtage'=>'badge-red','Frais'=>'badge-red','Retrait'=>'badge-yellow'}[row.tag] || 'badge-gray' %>
          <tr>
            <td style="color:#94a3b8;white-space:nowrap"><%= row.date %></td>
            <td><span class="badge <%= row.account == 'PEA' ? 'badge-blue' : 'badge-gray' %>"><%= row.account %></span></td>
            <td><span class="badge <%= row.kind == :trade ? 'badge-yellow' : 'badge-gray' %>"><%= row.kind == :trade ? 'Trade' : 'Cash' %></span></td>
            <td class="<%= row.amount && row.amount >= 0 ? 'positive' : 'negative' %>" style="white-space:nowrap"><%= row.amount && row.amount >= 0 ? '+' : '' %><%= row.amount&.round(2) %>€</td>
            <td><span class="badge <%= tag_color %>"><%= row.tag %></span></td>
            <td style="max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= row.name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if rows.size > 0 %>
    <div class="card" style="border-color:#0369a1">
      <h2>Confirmer l'import</h2>
      <p style="color:#94a3b8;font-size:0.875rem;margin-bottom:1rem">
        <%= rows.size %> transactions seront envoyées vers SUR. Import idempotent — relancer le même fichier ne crée pas de doublons.
      </p>
      <form id="confirm-form" method="post" action="/import" enctype="multipart/form-data">
        <input type="hidden" name="from_date" value="<%= params[:from_date] %>">
        <label>Re-sélectionnez le fichier CSV</label>
        <input type="file" name="file" id="confirm-file" accept=".csv" required style="margin-bottom:1rem">
        <button class="btn" style="background:#065f46;color:#6ee7b7" type="button" id="confirm-btn">
          Confirmer l'import (<%= rows.size %> transactions)
        </button>
      </form>
    </div>
  <% end %>
<% end %>
</div>

<!-- ── Scripts ────────────────────────────────────────────────── -->
<script>
(function() {
  // ── Discover ────────────────────────────────────────────────
  document.getElementById('discover-btn').addEventListener('click', function() {
    var btn = this;
    btn.textContent = '⏳ Chargement…';
    btn.disabled = true;
    fetch('/import/discover')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        document.getElementById('discover-result').style.display = 'block';
        document.getElementById('discover-json').textContent = JSON.stringify(data, null, 2);
        btn.textContent = '🔍 Vérifier comptes SUR';
        btn.disabled = false;
      })
      .catch(function(e) {
        document.getElementById('discover-result').style.display = 'block';
        document.getElementById('discover-json').textContent = 'Erreur: ' + e.message;
        btn.textContent = '🔍 Vérifier comptes SUR';
        btn.disabled = false;
      });
  });

  // ── Purge ─────────────────────────────────────────────────────
  function doPurge(what, btn) {
    var label = what === 'transactions' ? 'transactions' : 'trades';
    if (!confirm('Supprimer TOUTES les ' + label + ' Trade Republic dans SUR ?\nCette action est irréversible.')) return;
    btn.disabled = true;
    var orig = btn.textContent;
    btn.textContent = '⏳ Suppression…';
    document.getElementById('purge-status').textContent = '';
    var body = new URLSearchParams({ what: what });
    fetch('/import/purge', { method: 'POST', body: body })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var res = d[what] || d;
        document.getElementById('purge-status').textContent =
          '✓ ' + (res.deleted || 0) + ' supprimées' + (res.errors > 0 ? ', ' + res.errors + ' erreurs' : '');
        btn.textContent = orig;
        btn.disabled = false;
      })
      .catch(function(e) {
        document.getElementById('purge-status').textContent = 'Erreur: ' + e.message;
        btn.textContent = orig;
        btn.disabled = false;
      });
  }
  var ptBtn   = document.getElementById('purge-txn-btn');
  var ptrdBtn = document.getElementById('purge-trades-btn');
  if (ptBtn)   ptBtn.addEventListener('click',   function() { doPurge('transactions', ptBtn); });
  if (ptrdBtn) ptrdBtn.addEventListener('click', function() { doPurge('trades', ptrdBtn); });

  // ── Import réel (bouton principal) ───────────────────────────
  function startImport(fileInput, fromDate) {
    if (!fileInput || !fileInput.files[0]) {
      alert('Sélectionnez un fichier CSV');
      return;
    }
    var formData = new FormData();
    formData.append('file', fileInput.files[0]);
    formData.append('dry_run', 'false');
    formData.append('from_date', fromDate || '');

    document.getElementById('upload-card').style.display = 'none';
    document.getElementById('results-section').innerHTML = '';
    document.getElementById('progress-card').style.display = 'block';

    fetch('/import', { method: 'POST', body: formData })
      .then(function(r) {
        if (!r.ok) return r.json().then(function(d) { throw new Error(d.error || 'Erreur serveur'); });
        return r.json();
      })
      .then(function(data) {
        if (data.job_id) {
          pollJob(data.job_id);
        } else {
          showFatalError(data.error || 'Réponse inattendue');
        }
      })
      .catch(function(e) { showFatalError(e.message); });
  }

  document.getElementById('import-btn').addEventListener('click', function() {
    startImport(
      document.getElementById('file-input'),
      document.getElementById('from-date').value
    );
  });

  // ── Bouton confirmation après dry-run ────────────────────────
  var confirmBtn = document.getElementById('confirm-btn');
  if (confirmBtn) {
    confirmBtn.addEventListener('click', function() {
      startImport(
        document.getElementById('confirm-file'),
        '<%= params[:from_date] %>'
      );
    });
  }

  // ── Polling ──────────────────────────────────────────────────
  function pollJob(jobId) {
    var interval = setInterval(function() {
      fetch('/import/status/' + jobId)
        .then(function(r) { return r.json(); })
        .then(function(job) {
          updateProgress(job);
          if (job.status === 'done' || job.status === 'error') {
            clearInterval(interval);
            showResult(job);
          }
        })
        .catch(function() { /* ignore */ });
    }, 400);
  }

  function updateProgress(job) {
    var total = job.total || 0;
    var prog  = job.progress || 0;
    var pct   = total > 0 ? Math.round((prog / total) * 100) : 0;

    document.getElementById('progress-bar').style.width = pct + '%';
    document.getElementById('progress-pct').textContent = pct + '%';
    document.getElementById('p-ok').textContent     = job.ok     || 0;
    document.getElementById('p-errors').textContent = job.errors || 0;
    document.getElementById('p-skip').textContent   = job.skipped || 0;
    document.getElementById('p-total').textContent  = total || '—';

    var label = '';
    if (job.phase === 'démarrage')      label = 'Vérification des doublons…';
    else if (job.phase === 'import')    label = prog + ' / ' + total + ' transactions traitées';
    else if (job.phase === 'terminé')   label = 'Import terminé';
    else if (job.phase === 'erreur')    label = 'Erreur';
    document.getElementById('progress-label').textContent = label;
  }

  function showResult(job) {
    document.getElementById('progress-card').style.display = 'none';
    var html = '';

    if (job.status === 'error') {
      html = '<div class="card" style="border-color:#7f1d1d"><h2 style="color:#f87171">Erreur d\'import</h2><p style="color:#94a3b8;margin-top:0.5rem">' + escHtml(job.message) + '</p></div>';
      document.getElementById('results-section').innerHTML = html;
      document.getElementById('upload-card').style.display = 'block';
      return;
    }

    // Stats par tag
    var byTag = {};
    (job.rows || []).forEach(function(r) {
      if (!byTag[r.tag]) byTag[r.tag] = { count: 0, total: 0 };
      byTag[r.tag].count++;
      byTag[r.tag].total += r.amount;
    });

    var statsHtml = '<div style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-bottom:1.5rem">';
    Object.keys(byTag).forEach(function(tag) {
      var t = byTag[tag];
      var tot = Math.round(t.total * 100) / 100;
      var color = tot >= 0 ? '#4ade80' : '#f87171';
      statsHtml += '<div style="background:#0f172a;border:1px solid #334155;border-radius:0.5rem;padding:0.5rem 0.875rem;min-width:130px">' +
        '<div style="font-size:0.75rem;color:#64748b;margin-bottom:0.25rem">' + escHtml(tag) + '</div>' +
        '<div style="font-size:0.9rem;font-weight:600;color:' + color + '">' + (tot >= 0 ? '+' : '') + tot + '€</div>' +
        '<div style="font-size:0.75rem;color:#475569">' + t.count + ' ligne' + (t.count > 1 ? 's' : '') + '</div>' +
        '</div>';
    });
    statsHtml += '</div>';

    // Erreurs sample
    var errorsHtml = '';
    if (job.sample_errors && job.sample_errors.length > 0) {
      errorsHtml = '<div style="background:#450a0a;border:1px solid #7f1d1d;border-radius:0.5rem;padding:1rem;margin-bottom:1rem">' +
        '<div style="color:#f87171;font-weight:600;margin-bottom:0.5rem">Exemple d\'erreurs (' + job.errors + ' au total) :</div>';
      job.sample_errors.forEach(function(e) {
        errorsHtml += '<div style="font-size:0.8rem;color:#fca5a5;margin-bottom:0.25rem"><strong>' + escHtml(e.name) + '</strong> → ' + escHtml(e.error) + '</div>';
      });
      errorsHtml += '</div>';
    }

    // Cutoff trades
    var cutoffHtml = '';
    if (job.trade_cutoff) {
      cutoffHtml = '<div style="background:#0c4a6e;border:1px solid #0369a1;border-radius:0.5rem;padding:0.6rem 1rem;margin-bottom:1rem;font-size:0.85rem;color:#38bdf8">' +
        '📅 Trades filtrés à partir du <strong>' + job.trade_cutoff + '</strong> (date du dernier trade dans SUR)' +
        '</div>';
    }

    // Titre
    var skipNote = job.skipped > 0 ? ' <span style="font-size:0.85rem;font-weight:400;color:#64748b">(' + job.skipped + ' transactions déjà présentes)</span>' : '';
    var title = 'Résultat — ' + job.ok + ' importées, ' + job.errors + ' erreurs' + skipNote;

    // Table
    var tableHtml = '<table><thead><tr><th>Date</th><th>Compte</th><th>Montant</th><th>Catégorie</th><th>Libellé</th><th>Statut</th></tr></thead><tbody>';
    (job.rows || []).forEach(function(r) {
      var amtColor = r.amount >= 0 ? '#4ade80' : '#f87171';
      var amtStr   = (r.amount >= 0 ? '+' : '') + (Math.round(r.amount * 100) / 100) + '€';
      var accBadge = r.account === 'PEA'
        ? '<span class="badge badge-blue">PEA</span>'
        : '<span class="badge badge-gray">DEFAULT</span>';
      var tagColor = {Investissement:'badge-blue', Dividende:'badge-green', Dépôt:'badge-green', Taxes:'badge-red', 'Frais de courtage':'badge-red', Frais:'badge-red', Retrait:'badge-yellow'}[r.tag] || 'badge-gray';
      var statusBadge = r.status === 'ok'
        ? '<span class="badge badge-green">✓</span>'
        : '<span class="badge badge-red" title="' + escHtml(r.error || '') + '">✗ ' + escHtml((r.error || '').substring(0, 40)) + '</span>';
      tableHtml += '<tr>' +
        '<td style="color:#94a3b8;white-space:nowrap">' + escHtml(r.date) + '</td>' +
        '<td>' + accBadge + '</td>' +
        '<td style="color:' + amtColor + ';white-space:nowrap">' + amtStr + '</td>' +
        '<td><span class="badge ' + tagColor + '">' + escHtml(r.tag) + '</span></td>' +
        '<td style="max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="' + escHtml(r.name) + '">' + escHtml(r.name) + '</td>' +
        '<td>' + statusBadge + '</td>' +
        '</tr>';
    });
    tableHtml += '</tbody></table>';

    html = '<div class="card"><h2 style="margin-bottom:1rem">' + title + '</h2>' + cutoffHtml + errorsHtml + statsHtml + tableHtml + '</div>';
    document.getElementById('results-section').innerHTML = html;
  }

  function showFatalError(msg) {
    document.getElementById('progress-card').style.display = 'none';
    document.getElementById('upload-card').style.display = 'block';
    document.getElementById('results-section').innerHTML =
      '<div class="card" style="border-color:#7f1d1d"><p style="color:#f87171">' + escHtml(msg) + '</p></div>';
  }

  function escHtml(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Sauvegarde ticker inline ─────────────────────────────────────────────
  document.querySelectorAll('.save-ticker-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var isin   = btn.dataset.isin;
      var input  = document.getElementById('ticker-' + isin);
      var ticker = input.value.trim().toUpperCase();
      var name   = input.dataset.name || '';
      if (!ticker) { input.focus(); return; }

      btn.textContent = '…';
      btn.disabled = true;

      var body = new URLSearchParams({ isin: isin, ticker: ticker, name: name });
      fetch('/import/tickers', { method: 'POST', body: body })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.ok) {
            var row = document.getElementById('unmapped-row-' + isin);
            row.style.opacity = '0.4';
            row.style.textDecoration = 'line-through';
            btn.textContent = '✓ Sauvegardé';
            input.disabled = true;
            // Si plus aucune ligne active, masquer la card
            var remaining = document.querySelectorAll('.save-ticker-btn:not([disabled])');
            if (remaining.length === 0) {
              document.getElementById('unmapped-card').style.borderColor = '#16a34a';
              document.querySelector('#unmapped-card h2').textContent = '✅ Tous les titres mappés — relancez l\'aperçu';
            }
          } else {
            btn.textContent = 'Sauvegarder';
            btn.disabled = false;
          }
        })
        .catch(function() {
          btn.textContent = 'Sauvegarder';
          btn.disabled = false;
        });
    });
  });

  // Entrée clavier sur le champ ticker → déclenche save
  document.querySelectorAll('input[data-isin]').forEach(function(input) {
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        var btn = document.querySelector('.save-ticker-btn[data-isin="' + input.dataset.isin + '"]');
        if (btn) btn.click();
      }
    });
  });
})();
</script>
