<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MarketWatch — Connexion</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card { background: #1e293b; border: 1px solid #334155; border-radius: 0.75rem; padding: 2.5rem; width: 100%; max-width: 360px; }
    .brand { color: #38bdf8; font-size: 1.3rem; font-weight: 700; margin-bottom: 2rem; text-align: center; }
    label { display: block; font-size: 0.8rem; color: #64748b; margin-bottom: 0.4rem; }
    input { background: #0f172a; border: 1px solid #334155; color: #e2e8f0; padding: 0.6rem 0.75rem; border-radius: 0.375rem; font-size: 0.9rem; width: 100%; }
    input:focus { outline: none; border-color: #38bdf8; }
    button { margin-top: 1.5rem; width: 100%; padding: 0.65rem; background: #0369a1; color: white; border: none; border-radius: 0.375rem; font-size: 0.9rem; font-weight: 600; cursor: pointer; }
    button:hover { background: #0284c7; }
    .error { margin-top: 1rem; color: #f87171; font-size: 0.85rem; text-align: center; }
  </style>
</head>
<body>
  <div class="card">
    <div class="brand">MarketWatch</div>
    <form method="post" action="/login">
      <label for="password">Mot de passe</label>
      <input type="password" id="password" name="password" autofocus autocomplete="current-password">
      <button type="submit">Connexion</button>
    </form>
    <% if @error %>
      <p class="error"><%= @error %></p>
    <% end %>
  </div>
</body>
</html>
